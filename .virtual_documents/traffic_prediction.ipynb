import pandas as pd
import numpy as np
import warnings
warnings.filterwarnings("ignore")

from catboost import CatBoostRegressor
from sklearn.model_selection import KFold
from sklearn.metrics import r2_score

import geohash2









train = pd.read_csv("train.csv") 
test = pd.read_csv("test.csv") 
print(train.shape) 
print(test.shape) 
train.head()








# ============================================================
# GEOHASH DECODING FUNCTIONS
# ============================================================

def decode_lat(x):

    try:
        return geohash2.decode_exactly(str(x))[0]

    except:
        return np.nan


def decode_lon(x):

    try:
        return geohash2.decode_exactly(str(x))[1]

    except:
        return np.nan


# ============================================================
# FEATURE ENGINEERING
# ============================================================

def create_features(df):

    # ========================================================
    # TIME FEATURES
    # ========================================================

    # Extract hour and minute information from timestamps.
    # Traffic demand varies significantly throughout the day.

    df["hour"] = (
        df["timestamp"].str.split(":").str[0].astype(int)
    )

    df["minute"] = (
        df["timestamp"].str.split(":").str[1].astype(int)
    )

    # Continuous time representation

    df["time_minutes"] = (
        df["hour"] * 60 + df["minute"]
    )

    # Peak traffic hours

    df["is_peak_hour"] = (
        df["hour"].isin([7, 8, 9, 17, 18, 19]).astype(int)
    )

    # Weekend indicator

    df["is_weekend"] = (
        df["day"] % 7 >= 5
    ).astype(int)

    # Morning / Afternoon / Evening / Night

    df["time_block"] = pd.cut(
        df["hour"],
        bins=[0, 6, 10, 16, 20, 24],
        labels=[0, 1, 2, 3, 4],
        include_lowest=True
    ).astype(int)

    # ========================================================
    # GEOHASH FEATURES
    # ========================================================

    # Decode geohash to latitude and longitude

    df["latitude"] = (
        df["geohash"].apply(decode_lat)
    )

    df["longitude"] = (
        df["geohash"].apply(decode_lon)
    )

    # Spatial interaction features

    df["lat_lon"] = (
        df["latitude"] * df["longitude"]
    )

    df["lat_sq"] = (
        df["latitude"] ** 2
    )

    df["lon_sq"] = (
        df["longitude"] ** 2
    )

    # ========================================================
    # CYCLICAL TIME FEATURES
    # ========================================================

    # Hour is cyclical

    df["hour_sin"] = np.sin(
        2 * np.pi * df["hour"] / 24
    )

    df["hour_cos"] = np.cos(
        2 * np.pi * df["hour"] / 24
    )

    # ========================================================
    # BASIC INTERACTION FEATURES
    # ========================================================

    df["geo_road"] = (
        df["geohash"].astype(str) + "_" + df["RoadType"].astype(str)
    )

    df["road_vehicle"] = (
        df["RoadType"].astype(str) + "_" + df["LargeVehicles"].astype(str)
    )

    df["geo_vehicle"] = (
        df["geohash"].astype(str) + "_" + df["LargeVehicles"].astype(str)
    )

    # ========================================================
    # ROAD + TIME INTERACTIONS
    # ========================================================

    df["road_hour"] = (
        df["RoadType"].astype(str) + "_" + df["hour"].astype(str)
    )

    df["weather_hour"] = (
        df["Weather"].astype(str) + "_" + df["hour"].astype(str)
    )

    df["weather_road"] = (
        df["Weather"].astype(str) + "_" + df["RoadType"].astype(str)
    )

    # ========================================================
    # LANDMARK INTERACTIONS
    # ========================================================

    df["landmark_hour"] = (
        df["Landmarks"].astype(str) + "_" + df["hour"].astype(str)
    )

    df["landmark_road"] = (
        df["Landmarks"].astype(str) + "_" + df["RoadType"].astype(str)
    )

    # ========================================================
    # ADVANCED LOCATION INTERACTIONS
    # ========================================================

    df["geo_road_vehicle"] = (
        df["geohash"].astype(str)
        + "_"
        + df["RoadType"].astype(str)
        + "_"
        + df["LargeVehicles"].astype(str)
    )

    # ========================================================
    # ROAD CAPACITY FEATURES
    # ========================================================

    # Estimate road handling capability

    # df["road_capacity_score"] = (
    #     df["NumberofLanes"]
    #     * (1 + df["LargeVehicles"])
    # )

    # df["lane_density"] = (
    #     df["NumberofLanes"]
    #     /
    #     (df["road_capacity_score"] + 1)
    # )

    # Road type + lane count

    df["road_lanes"] = (
        df["RoadType"].astype(str)
        + "_"
        + df["NumberofLanes"].astype(str)
    )

    # ========================================================
    # WEATHER FEATURES
    # ========================================================

    df["weather_peak"] = (
        df["Weather"].astype(str)
        + "_"
        + df["is_peak_hour"].astype(str)
    )

    # Temperature buckets

    df["temp_bucket"] = pd.cut(
        df["Temperature"],
        bins=8,
        labels=False
    )

    df["temp_weather"] = (
        df["Weather"].astype(str)
        + "_"
        + df["temp_bucket"].astype(str)
    )

    # ========================================================
    # GEO CLUSTER FEATURES
    # ========================================================

    df["lat_round"] = (
        df["latitude"]
        .round(2)
    )

    df["lon_round"] = (
        df["longitude"]
        .round(2)
    )

    df["geo_cluster"] = (
        df["lat_round"].astype(str)
        + "_"
        + df["lon_round"].astype(str)
    )

    return df





train = create_features(train) 
test = create_features(test)

print(train.shape)








def target_encode(train_df, test_df, col):
    global_mean = train_df["demand"].mean()

    mapping = (
        train_df.groupby(col)["demand"].mean()
    )

    train_df[col + "_te"] = (
        train_df[col].map(mapping).fillna(global_mean)
    )

    test_df[col + "_te"] = (
        test_df[col].map(mapping).fillna(global_mean)
    )

    return train_df, test_df

for col in [
    "RoadType",
    "Weather",
    "geohash",
    "road_hour",
    "geo_road",
    "weather_road"
]:
    train, test = target_encode(
        train,
        test,
        col
    )








freq = train["geohash"].value_counts() 
train["geo_freq"] = ( 
    train["geohash"] .map(freq) 
) 
test["geo_freq"] = ( 
    test["geohash"] .map(freq) 
)








TARGET = "demand" 
drop_cols = [ "Index", "timestamp", "demand" ] 
features = [ 
    c 
    for c in train.columns 
    if c not in drop_cols 
] 
X = train[features].copy() 
y = train[TARGET] 
X_test = test[features].copy() 
print(len(features))








cat_cols = [
    "geohash",
    "RoadType",
    "LargeVehicles",
    "Landmarks",
    "Weather",
    "geo_road",
    "road_vehicle",
    "geo_vehicle",
    "road_hour",
    "weather_hour",
    "weather_road",
    "landmark_hour",
    "geo_cluster",
    "geo_road_vehicle",
    "landmark_road",
    "road_lanes",
    "weather_peak",
    "temp_weather"
]








for col in cat_cols:
    X[col] = (
        X[col].fillna("Unknown").astype(str)
    )
    X_test[col] = (
        X_test[col].fillna("Unknown").astype(str)
    )

num_cols = X.select_dtypes(
    include=np.number
).columns

for col in num_cols:

    med = X[col].median()
    X[col] = X[col].fillna(med)
    X_test[col] = X_test[col].fillna(med)

print("Done")








kf = KFold( 
    n_splits=5, 
    shuffle=True, 
    random_state=42 
) 
oof = np.zeros(len(X)) 
pred_test = np.zeros(len(X_test)) 
scores = []








for fold, (train_idx, valid_idx) in enumerate(kf.split(X)): 
    print("="*50) 
    print("FOLD:", fold+1) 
    X_train = X.iloc[train_idx] 
    X_valid = X.iloc[valid_idx] 
    y_train = y.iloc[train_idx] 
    y_valid = y.iloc[valid_idx] 
    model = CatBoostRegressor(
        iterations=5000,
        learning_rate=0.02,
        depth=10,
        l2_leaf_reg=5,
        loss_function="RMSE",
        random_seed=42,
        verbose=300
    )
    model.fit(
        X_train, y_train, cat_features=cat_cols, eval_set=(X_valid, y_valid), early_stopping_rounds=200 
    ) 
    val_preds = model.predict(X_valid) 
    score = r2_score( y_valid, val_preds ) 
    print("Fold R2 =", score) 
    scores.append(score) 
    oof[valid_idx] = val_preds 
    pred_test += ( model.predict(X_test) / 5 )








final_score = r2_score( y, oof ) 
print() 
print("CV SCORE =", final_score) 
print("FOLDS =", scores)








fi = pd.DataFrame({
    "feature": X.columns, "importance": model.get_feature_importance() 
}) 
fi = fi.sort_values(
    "importance", ascending=False 
) 
fi.head(30)








submission = pd.DataFrame({
    "Index": test["Index"], "demand": pred_test 
}) 
submission.to_csv( 
    "submission.csv", index=False 
) 
