import pandas as pd
import numpy as np
import warnings
warnings.filterwarnings("ignore")

from catboost import CatBoostRegressor
from lightgbm import LGBMRegressor
from xgboost import XGBRegressor
from sklearn.model_selection import KFold
from sklearn.metrics import r2_score
import geohash2





train = pd.read_csv("train.csv")
test = pd.read_csv("test.csv")
print("Train:", train.shape)
print("Test:", test.shape)
train.head()





def decode_lat(x):
    try:
        return geohash2.decode_exactly(str(x))[0]
    except:
        return np.nan

def decode_lon(x):
    try:
        return geohash2.decode_exactly(str(x))[1]
    except:
        return np.nan

def create_features(df):
    # Time features
    df["hour"] = df["timestamp"].str.split(":").str[0].astype(int)
    df["minute"] = df["timestamp"].str.split(":").str[1].astype(int)
    df["time_minutes"] = df["hour"] * 60 + df["minute"]
    
    # Peak hours (morning + evening rush)
    df["is_peak_hour"] = df["hour"].isin([7, 8, 9, 17, 18, 19]).astype(int)
    
    # Day of week (assuming day is sequential)
    df["day_of_week"] = df["day"] % 7
    df["is_weekend"] = (df["day_of_week"] >= 5).astype(int)
    
    # Time block
    df["time_block"] = pd.cut(df["hour"], bins=[0, 6, 10, 16, 20, 24],
                              labels=[0, 1, 2, 3, 4], include_lowest=True).astype(int)
    
    # Cyclical time features
    df["hour_sin"] = np.sin(2 * np.pi * df["hour"] / 24)
    df["hour_cos"] = np.cos(2 * np.pi * df["hour"] / 24)
    df["day_sin"] = np.sin(2 * np.pi * df["day_of_week"] / 7)
    df["day_cos"] = np.cos(2 * np.pi * df["day_of_week"] / 7)
    df["minute_sin"] = np.sin(2 * np.pi * df["minute"] / 60)
    df["minute_cos"] = np.cos(2 * np.pi * df["minute"] / 60)
    
    # Geohash decode
    df["latitude"] = df["geohash"].apply(decode_lat)
    df["longitude"] = df["geohash"].apply(decode_lon)
    
    # Geo cluster
    df["lat_round"] = df["latitude"].round(2)
    df["lon_round"] = df["longitude"].round(2)
    df["geo_cluster"] = df["lat_round"].astype(str) + "_" + df["lon_round"].astype(str)
    
    # Interaction features
    df["geo_road"] = df["geohash"].astype(str) + "_" + df["RoadType"].astype(str)
    df["road_vehicle"] = df["RoadType"].astype(str) + "_" + df["LargeVehicles"].astype(str)
    df["geo_vehicle"] = df["geohash"].astype(str) + "_" + df["LargeVehicles"].astype(str)
    df["road_hour"] = df["RoadType"].astype(str) + "_" + df["hour"].astype(str)
    df["weather_hour"] = df["Weather"].astype(str) + "_" + df["hour"].astype(str)
    df["weather_road"] = df["Weather"].astype(str) + "_" + df["RoadType"].astype(str)
    df["landmark_hour"] = df["Landmarks"].astype(str) + "_" + df["hour"].astype(str)
    df["geo_day"] = df["geohash"].astype(str) + "_" + df["day_of_week"].astype(str)
    df["geo_timeblock"] = df["geohash"].astype(str) + "_" + df["time_block"].astype(str)
    df["road_weekend"] = df["RoadType"].astype(str) + "_" + df["is_weekend"].astype(str)
    df["weather_weekend"] = df["Weather"].astype(str) + "_" + df["is_weekend"].astype(str)
    df["lanes_vehicle"] = df["NumberofLanes"].astype(str) + "_" + df["LargeVehicles"].astype(str)
    
    # NumberofLanes as numeric feature squared
    df["lanes_sq"] = df["NumberofLanes"] ** 2
    
    # Temperature interactions
    df["temp_hour"] = df["Temperature"] * df["hour"]
    df["temp_lanes"] = df["Temperature"] * df["NumberofLanes"]
    
    return df

train = create_features(train)
test = create_features(test)
print("Train shape after features:", train.shape)





# Compute geo-level statistics from train — these capture location-specific demand patterns
geo_stats = train.groupby("geohash")["demand"].agg(["mean", "std", "median", "min", "max"]).reset_index()
geo_stats.columns = ["geohash", "geo_demand_mean", "geo_demand_std", "geo_demand_median", "geo_demand_min", "geo_demand_max"]

train = train.merge(geo_stats, on="geohash", how="left")
test = test.merge(geo_stats, on="geohash", how="left")

# Geo + hour level stats
geo_hour_stats = train.groupby(["geohash", "hour"])["demand"].agg(["mean", "std"]).reset_index()
geo_hour_stats.columns = ["geohash", "hour", "geo_hour_mean", "geo_hour_std"]

train = train.merge(geo_hour_stats, on=["geohash", "hour"], how="left")
test = test.merge(geo_hour_stats, on=["geohash", "hour"], how="left")

# Road type stats
road_stats = train.groupby("RoadType")["demand"].agg(["mean", "std"]).reset_index()
road_stats.columns = ["RoadType", "road_demand_mean", "road_demand_std"]

train = train.merge(road_stats, on="RoadType", how="left")
test = test.merge(road_stats, on="RoadType", how="left")

# Frequency encoding
freq = train["geohash"].value_counts()
train["geo_freq"] = train["geohash"].map(freq)
test["geo_freq"] = test["geohash"].map(freq)

print("Train shape after aggregations:", train.shape)





TARGET = "demand"
drop_cols = ["Index", "timestamp", "demand"]
features = [c for c in train.columns if c not in drop_cols]

X = train[features].copy()
y = train[TARGET]
X_test = test[features].copy()

# Categorical columns for CatBoost
cat_cols = [
    "geohash", "RoadType", "LargeVehicles", "Landmarks", "Weather",
    "geo_road", "road_vehicle", "geo_vehicle", "road_hour", "weather_hour",
    "weather_road", "landmark_hour", "geo_cluster", "geo_day", "geo_timeblock",
    "road_weekend", "weather_weekend", "lanes_vehicle"
]

# Fill missing
for col in cat_cols:
    X[col] = X[col].fillna("Unknown").astype(str)
    X_test[col] = X_test[col].fillna("Unknown").astype(str)

num_cols = X.select_dtypes(include=np.number).columns
for col in num_cols:
    med = X[col].median()
    X[col] = X[col].fillna(med)
    X_test[col] = X_test[col].fillna(med)

print(f"Features: {len(features)}")
print(f"Cat cols: {len(cat_cols)}")





def fold_target_encode(X_train, X_valid, X_test_full, y_train, cols):
    """Target encode inside fold to prevent leakage"""
    global_mean = y_train.mean()
    
    for col in cols:
        mapping = pd.Series(y_train.values, index=X_train[col].values).groupby(level=0).mean()
        
        X_train[col + "_te"] = X_train[col].map(mapping).fillna(global_mean)
        X_valid[col + "_te"] = X_valid[col].map(mapping).fillna(global_mean)
        X_test_full[col + "_te"] = X_test_full[col].map(mapping).fillna(global_mean)
    
    return X_train, X_valid, X_test_full

te_cols = ["RoadType", "Weather", "geohash", "road_hour", "geo_road", 
           "weather_road", "geo_day", "geo_timeblock", "landmark_hour"]





kf = KFold(n_splits=5, shuffle=True, random_state=42)

oof_cat = np.zeros(len(X))
oof_lgb = np.zeros(len(X))
oof_xgb = np.zeros(len(X))

pred_test_cat = np.zeros(len(X_test))
pred_test_lgb = np.zeros(len(X_test))
pred_test_xgb = np.zeros(len(X_test))

scores_cat = []
scores_lgb = []
scores_xgb = []

for fold, (train_idx, valid_idx) in enumerate(kf.split(X)):
    print("=" * 60)
    print(f"FOLD {fold + 1}")
    print("=" * 60)
    
    X_train = X.iloc[train_idx].copy()
    X_valid = X.iloc[valid_idx].copy()
    y_train = y.iloc[train_idx]
    y_valid = y.iloc[valid_idx]
    X_test_fold = X_test.copy()
    
    # Target encoding inside fold (NO LEAKAGE)
    X_train, X_valid, X_test_fold = fold_target_encode(
        X_train, X_valid, X_test_fold, y_train, te_cols
    )
    
    # Get all feature names after TE
    fold_features = X_train.columns.tolist()
    
    # --- CatBoost ---
    model_cat = CatBoostRegressor(
        iterations=6000,
        learning_rate=0.015,
        depth=10,
        l2_leaf_reg=5,
        loss_function="RMSE",
        random_seed=42 + fold,
        verbose=500,
        min_data_in_leaf=20,
        subsample=0.85,
        colsample_bylevel=0.8
    )
    
    cat_features_idx = [i for i, c in enumerate(fold_features) if c in cat_cols]
    
    model_cat.fit(
        X_train[fold_features], y_train,
        cat_features=cat_features_idx,
        eval_set=(X_valid[fold_features], y_valid),
        early_stopping_rounds=300,
        verbose=500
    )
    
    val_preds_cat = model_cat.predict(X_valid[fold_features])
    score_cat = r2_score(y_valid, val_preds_cat)
    print(f"  CatBoost Fold R² = {score_cat:.6f}")
    scores_cat.append(score_cat)
    oof_cat[valid_idx] = val_preds_cat
    pred_test_cat += model_cat.predict(X_test_fold[fold_features]) / 5
    
    # --- LightGBM (needs numeric features only) ---
    # Convert cat cols to category codes for LightGBM
    X_train_lgb = X_train[fold_features].copy()
    X_valid_lgb = X_valid[fold_features].copy()
    X_test_lgb = X_test_fold[fold_features].copy()
    
    for col in cat_cols:
        if col in X_train_lgb.columns:
            X_train_lgb[col] = X_train_lgb[col].astype("category")
            X_valid_lgb[col] = X_valid_lgb[col].astype("category")
            X_test_lgb[col] = X_test_lgb[col].astype("category")
    
    model_lgb = LGBMRegressor(
        n_estimators=6000,
        learning_rate=0.015,
        max_depth=12,
        num_leaves=128,
        min_child_samples=20,
        subsample=0.85,
        colsample_bytree=0.8,
        reg_alpha=0.1,
        reg_lambda=5,
        random_state=42 + fold,
        verbose=-1
    )
    
    model_lgb.fit(
        X_train_lgb, y_train,
        eval_set=[(X_valid_lgb, y_valid)],
        callbacks=[
            __import__('lightgbm').early_stopping(300),
            __import__('lightgbm').log_evaluation(500)
        ]
    )
    
    val_preds_lgb = model_lgb.predict(X_valid_lgb)
    score_lgb = r2_score(y_valid, val_preds_lgb)
    print(f"  LightGBM Fold R² = {score_lgb:.6f}")
    scores_lgb.append(score_lgb)
    oof_lgb[valid_idx] = val_preds_lgb
    pred_test_lgb += model_lgb.predict(X_test_lgb) / 5
    
    # --- XGBoost (numeric only, drop cat string cols) ---
    num_features = [c for c in fold_features if c not in cat_cols]
    
    model_xgb = XGBRegressor(
        n_estimators=5000,
        learning_rate=0.015,
        max_depth=10,
        min_child_weight=20,
        subsample=0.85,
        colsample_bytree=0.8,
        reg_alpha=0.1,
        reg_lambda=5,
        random_state=42 + fold,
        verbosity=0,
        tree_method="hist"
    )
    
    model_xgb.fit(
        X_train[num_features], y_train,
        eval_set=[(X_valid[num_features], y_valid)],
        verbose=False
    )
    
    val_preds_xgb = model_xgb.predict(X_valid[num_features])
    score_xgb = r2_score(y_valid, val_preds_xgb)
    print(f"  XGBoost Fold R² = {score_xgb:.6f}")
    scores_xgb.append(score_xgb)
    oof_xgb[valid_idx] = val_preds_xgb
    pred_test_xgb += model_xgb.predict(X_test_fold[num_features]) / 5
    
    print()





# Weighted ensemble — CatBoost typically strongest on this data
W_CAT = 0.50
W_LGB = 0.35
W_XGB = 0.15

oof_ensemble = W_CAT * oof_cat + W_LGB * oof_lgb + W_XGB * oof_xgb
pred_test_ensemble = W_CAT * pred_test_cat + W_LGB * pred_test_lgb + W_XGB * pred_test_xgb

print("=" * 60)
print("INDIVIDUAL MODEL SCORES:")
print(f"  CatBoost CV R²:  {r2_score(y, oof_cat):.6f}")
print(f"  LightGBM CV R²:  {r2_score(y, oof_lgb):.6f}")
print(f"  XGBoost CV R²:   {r2_score(y, oof_xgb):.6f}")
print()
print(f"  ENSEMBLE CV R²:  {r2_score(y, oof_ensemble):.6f}")
print("=" * 60)

# Try different weights to find optimal
best_score = 0
best_w = (0.5, 0.35, 0.15)
for w1 in np.arange(0.3, 0.7, 0.05):
    for w2 in np.arange(0.2, 0.6, 0.05):
        w3 = 1 - w1 - w2
        if w3 < 0.05:
            continue
        oof_try = w1 * oof_cat + w2 * oof_lgb + w3 * oof_xgb
        s = r2_score(y, oof_try)
        if s > best_score:
            best_score = s
            best_w = (w1, w2, w3)

print(f"\nOptimal weights: CatBoost={best_w[0]:.2f}, LightGBM={best_w[1]:.2f}, XGBoost={best_w[2]:.2f}")
print(f"Optimal Ensemble R²: {best_score:.6f}")

# Use optimal weights for final prediction
pred_final = best_w[0] * pred_test_cat + best_w[1] * pred_test_lgb + best_w[2] * pred_test_xgb





# Clip predictions to valid range
pred_final = np.clip(pred_final, 0, None)

submission = pd.DataFrame({
    "Index": test["Index"],
    "demand": pred_final
})
submission.to_csv("submission.csv", index=False)
print("submission.csv created!")
print(f"\nPrediction stats:")
print(submission["demand"].describe())
submission.head(10)



